# --- Servidor ---
NODE_ENV=development
PORT=4000
# URL publica del sitio (se usa para CORS y back_urls de Mercado Pago)
FRONTEND_URL=http://localhost:4000

# --- Base de datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rideon_foto
DB_USER=rideon_user
DB_PASSWORD=cambiar_esta_password

# --- JWT (auth del dashboard del fotografo) ---
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# --- Usuario fotografo inicial (usado por el seeder de configuraciones/admin) ---
ADMIN_EMAIL=fotografo@rideon.com
ADMIN_PASSWORD=cambiar_esta_password
ADMIN_NOMBRE=Administrador RIDEON

# --- Storage S3-compatible (AWS S3, Cloudflare R2, Backblaze B2, etc.) ---
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Bucket privado: fotos originales en alta resolucion, SIN acceso publico
S3_BUCKET_ORIGINALS=rideon-fotos-originales
# Bucket/prefijo publico: previews comprimidos y con marca de agua
S3_BUCKET_PREVIEWS=rideon-fotos-previews
# URL base publica desde donde se sirven los previews (CDN o dominio del bucket publico)
S3_PUBLIC_BASE_URL=https://rideon-fotos-previews.s3.amazonaws.com

# --- Marca de agua ---
# Texto usado si no se sube una imagen de marca de agua desde el dashboard (editable desde /api/configuraciones)
WATERMARK_TEXT=RIDEON FOTO DEPORTIVA

# --- Mercado Pago ---
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
# Secreto para validar la firma x-signature del webhook (Panel de MP > Notificaciones webhook)
MP_WEBHOOK_SECRET=cambiar_por_el_secreto_del_webhook

# --- Descargas firmadas ---
DOWNLOAD_TOKEN_EXPIRATION_HOURS=48

# --- Email (nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=cuenta@gmail.com
SMTP_PASS=cambiar_esta_password
SMTP_FROM="RIDEON FOTO DEPORTIVA <no-reply@rideon.com>"
